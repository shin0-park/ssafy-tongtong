# Django 서버 전용 설정입니다. 실제 값은 .env에만 넣고 문서/프론트/로그에 노출하지 않습니다.
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=

# Vue 개발 서버와 Django API가 cookie를 주고받기 위한 CORS/CSRF 설정입니다.
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# refresh token cookie 속성입니다. 배포 HTTPS 환경에서는 secure 설정을 별도로 점검합니다.
JWT_REFRESH_COOKIE_SECURE=false
JWT_REFRESH_COOKIE_SAMESITE=Lax

# 정보나루 API 키는 서버에서만 사용합니다. 프론트엔드 환경변수로 옮기지 않습니다.
DATA4LIBRARY_API_KEY=
DATA4LIBRARY_BASE_URL=http://data4library.kr/api

# data.go.kr 공휴일 API 키도 서버 전용입니다. 운영표/공휴일 수집에 사용됩니다.
DATA_GO_KR_API_KEY=
PUBLIC_HOLIDAY_API_BASE_URL=http://apis.data.go.kr/B090041/openapi/service/SpcdeInfoService
PUBLIC_HOLIDAY_API_OPERATION=getRestDeInfo
PUBLIC_HOLIDAY_API_NUM_OF_ROWS=20

# GMS는 나의 나들이 summary_sentence 표현 보조용입니다.
# 추천 후보, 추천 순위, 도서관 사실/시설/운영 판정에는 사용하지 않습니다.
GMS_API_KEY=
GMS_OPENAI_BASE_URL=
GMS_MODEL=
GMS_SUMMARY_ENABLED=false
GMS_TIMEOUT_SECONDS=3

# 사용자 업로드 이미지 검증에 쓰는 서버 설정입니다.
MEDIA_MAX_UPLOAD_MB=10
